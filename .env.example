# LLM providers
# Required: default provider. Get a key at https://aistudio.google.com/
GEMINI_API_KEY=
# Optional: Claude support is scaffolded but not yet selectable as a provider.
ANTHROPIC_API_KEY=

# YouTube Data API v3 — required for YouTube collector
# Get a key at https://console.cloud.google.com/
YOUTUBE_API_KEY=

# Telegram bot credentials — required for delivery
# Create a bot via @BotFather; get the chat ID via @userinfobot or the getUpdates API
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
